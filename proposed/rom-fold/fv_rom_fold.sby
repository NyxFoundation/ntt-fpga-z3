[tasks]
bmc

[options]
# 10-bit address space, 1-cycle ROMs, assertions time-local with
# unconstrained initial state: depth 6 BMC covers every case.
bmc: mode bmc
bmc: depth 6

[engines]
smtbmc yices

[script]
read -formal -sv fv_rom_fold.sv
read -formal tf_rom_fold.v
read -formal tf_ROM.v
prep -top fv_rom_fold

[files]
fv_rom_fold.sv
tf_rom_fold.v
../../cfntt_ref/hardware_code_radix-2/tf_ROM.v
